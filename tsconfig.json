// Lint / IDE / typecheck config. Covers src + scripts + tests, emits nothing.
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": ["src/index.ts", "src/pratt/**/*.ts", "scripts/**/*.ts"]
}
